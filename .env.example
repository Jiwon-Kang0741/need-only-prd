# Copy to .env and fill in your keys (never commit .env)

CODEX_AZURE_OPENAI_ENDPOINT=https://your-codex-resource.cognitiveservices.azure.com
CODEX_AZURE_OPENAI_API_VERSION=2025-04-01-preview
CODEX_AZURE_OPENAI_MODEL_NAME=gpt-5.3-codex
CODEX_AZURE_OPENAI_API_KEY=your-codex-api-key

AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MODEL_NAME=gpt-5.4
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# PFY local deploy mode (optional; default is docker)
CODEGEN_DEPLOY_MODE=docker
PFY_BACKEND_DIR=C:/workspace_pfy/PFY/pfy
PFY_FRONT_DIR=C:/workspace_pfy/PFY/pfy-front
PFY_MAVEN_OPTS=-Xmx2048m
PFY_BACKEND_DEV_PORT=8888
PFY_FRONT_DEV_PORT=8081

# --- Mockup Pipeline 전용 (원본 pfy-front 사내 AOAI 게이트웨이) ---
# 설정하지 않으면 Mockup 탭 사용 시 에러 메시지가 표시됩니다.
MOCKUP_AOAI_ENDPOINT=https://ito-ax.apps.dev.honecloud.co.kr/api/hub/v1/models/gpt-5.2/invoke
MOCKUP_AOAI_API_KEY=your-mockup-api-key
MOCKUP_AOAI_DEPLOYMENT=gpt-5.2
MOCKUP_AOAI_MAX_TOKENS=8000

# --- MockupBuilder scaffolding 서버용 (원본 pfy-front AOAI 게이트웨이 직접 호출) ---
# USE_LLM_PROXY=true: 우리 FastAPI 백엔드(gpt-5.4)를 통해 LLM 호출 (VPN 불필요)
# USE_LLM_PROXY=false: AOAI_ENDPOINT를 직접 호출 (사내 VPN 필요, gpt-5.2)
USE_LLM_PROXY=false
AOAI_ENDPOINT=https://ito-ax.apps.dev.honecloud.co.kr/api/hub/v1/models/gpt-5.2/invoke
AOAI_API_KEY=your-aoai-api-key
AOAI_DEPLOYMENT=gpt-5.2
