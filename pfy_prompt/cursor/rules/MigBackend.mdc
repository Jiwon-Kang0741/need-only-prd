package hsc.tomms.web.pm.dp.dto.request;

import lombok.Data;
import lombok.EqualsAndHashCode;
import hsc.tomms.web.common.dto.base.SearchBaseDto;

/**
 * <pre>
 * <li>SYSTEM      : TOMMS Lite
 * <li>BUSINESS    : 수리부속 - 일반보급 - 요청
 * <li>FILE NAME   : Pm020SearchListReqDto / 부품요청목록조회요청DTO
 * <li>DESCRIPTION : 부품요청목록조회요청DTO
 * -------------------------------------------------------------------------------
 * 2025.12.10	홍길동(202500001)	최초작성
 * -------------------------------------------------------------------------------
 * </pre>
 */
@Data
@EqualsAndHashCode(callSuper = false)
public class Pm020SearchListReqDto extends SearchBaseDto {
    
    /** 요청번호 (선택) */
    private String reqNo;
    
    /** 품목코드 (선택) */
    private String itemCode;
    
    /** 상태코드 (선택) */
    private String statusCode;
    
    /** 시작일 (선택) */
    private String startDate;
    
    /** 종료일 (선택) */
    private String endDate;
    
    /** 검색어 (선택) */
    private String searchText;
}
```

**참고**: 
- 페이징 관련 필드(`page`, `size`)는 `SearchBaseDto`에 이미 정의되어 있으므로 생략
- 상속하지 않는 단순 DTO는 `@Data`만 사용

