package hsc.tomms.web.im.ir.service;

import hone.bom.annotation.ServiceId;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import org.springframework.util.StringUtils;
import java.util.*;

/**
 * <pre>
 * <li>SYSTEM      : TOMMS Lite
 * <li>BUSINESS    : 수리부속 - 일반보급 - 요청
 * <li>FILE NAME   : PMDP020ServiceImpl / 부품요청서비스구현체
 * <li>DESCRIPTION : 부품요청서비스구현체
 * -------------------------------------------------------------------------------
 * 2025.12.10	홍길동(202500001)	최초작성
 * -------------------------------------------------------------------------------
 * </pre>
 */
@Service("PMDP020Service-부품요청")
public class PMDP020ServiceImpl implements PMDP020Service {
    
    private static final Logger logger = LoggerFactory.getLogger(PMDP020ServiceImpl.class);
    
    @Autowired
    private PMDP020Dao pmdp020Dao;
    
    /**
     * 부품요청 목록 조회
     * API: POST /api/v1/PMDP020/searchList
     * 
     * @param request 부품요청목록조회요청DTO
     * @return List<Pm020SearchListResDto> 부품요청목록응답DTO목록
     */
    @Override
    @ServiceId("PMDP020/searchList")
    public List<Pm020SearchListResDto> searchList(Pm020SearchListReqDto request) {
        logger.debug("Service Method : searchList, Input Param={}", request.toString());
        
        // Validation
        if (!StringUtils.hasText(request.getStartDate())) {
            throw new IllegalArgumentException("시작일은 필수입니다.");
        }
        if (!StringUtils.hasText(request.getEndDate())) {
            throw new IllegalArgumentException("종료일은 필수입니다.");
        }
        
        // DAO 호출
        List<Pm020SearchListResDto> result = pmdp020Dao.searchList(request);
        
        logger.debug("부품요청 목록 조회 완료: {} 건", result.size());
        return result;
    }
    
    /**
     * 부품요청 상세 조회
     * API: POST /api/v1/PMDP020/selectDetail
     * 
     * @param request 부품요청상세조회요청DTO
     * @return Pm020SelectDetailResDto 부품요청상세응답DTO
     */
    @Override
    @ServiceId("PMDP020/selectDetail")
    public Pm020SelectDetailResDto selectDetail(Pm020SelectDetailReqDto request) {
        logger.debug("Service Method : selectDetail, Input Param={}", request.toString());
        
        // Validation
        if (!StringUtils.hasText(request.getReqId())) {
            throw new IllegalArgumentException("요청ID는 필수입니다.");
        }
        
        // DAO 호출
        Pm020SelectDetailResDto result = pmdp020Dao.selectDetail(request);
        
        if (result == null) {
            throw new IllegalArgumentException("데이터를 찾을 수 없습니다.");
        }
        
        logger.debug("부품요청 상세 조회 완료: {}", result);
        return result;
    }
    
    /**
     * 부품요청 저장 (등록/수정)
     * API: POST /api/v1/PMDP020/save
     * 
     * @param request 부품요청저장요청DTO
     * @return Pm020SaveResDto 저장결과
     */
    @Override
    @Transactional
    @ServiceId("PMDP020/save")
    public Pm020SaveResDto save(Pm020SaveReqDto request) {
        logger.debug("Service Method : save, Input Param={}", request.toString());
        
        // Validation
        validateSave(request);
        
        try {
            int result = 0;
            if (!StringUtils.hasText(request.getReqId())) {
                // 등록
                result = pmdp020Dao.insert(request);
            } else {
                // 수정
                result = pmdp020Dao.update(request);
            }
            
            Pm020SaveResDto response = new Pm020SaveResDto();
            response.setSuccess(result > 0);
            response.setMessage(result > 0 ? "저장되었습니다." : "저장 실패");
            
            logger.debug("부품요청 저장 완료: {} 건", result);
            return response;
            
        } catch (Exception e) {
            logger.error("부품요청 저장 오류: {}", e.getMessage(), e);
            throw new RuntimeException("부품요청 저장에 실패했습니다.", e);
        }
    }
    
    /**
     * 부품요청 삭제
     * API: POST /api/v1/PMDP020/delete
     * 
     * @param reqId 요청ID
     * @return Pm020SaveResDto 삭제결과
     */
    @Override
    @Transactional
    @ServiceId("PMDP020/delete")
    public Pm020SaveResDto delete(String reqId) {
        logger.debug("Service Method : delete, Input Param={}", reqId);
        
        // Validation
        if (!StringUtils.hasText(reqId)) {
            throw new IllegalArgumentException("요청ID는 필수입니다.");
        }
        
        try {
            int result = pmdp020Dao.delete(reqId);
            
            Pm020SaveResDto response = new Pm020SaveResDto();
            response.setSuccess(result > 0);
            response.setMessage(result > 0 ? "삭제되었습니다." : "삭제 실패");
            
            logger.debug("부품요청 삭제 완료: {} 건", result);
            return response;
            
        } catch (Exception e) {
            logger.error("부품요청 삭제 오류: {}", e.getMessage(), e);
            throw new RuntimeException("부품요청 삭제에 실패했습니다.", e);
        }
    }
    
    /**
     * 부품요청 저장 Validation
     * 
     * @param request 부품요청저장요청DTO
     */
    private void validateSave(Pm020SaveReqDto request) {
        if (!StringUtils.hasText(request.getItemCode())) {
            throw new IllegalArgumentException("품목코드는 필수입니다.");
        }
        if (request.getQty() <= 0) {
            throw new IllegalArgumentException("수량은 1 이상이어야 합니다.");
        }
        if (!StringUtils.hasText(request.getReqDate())) {
            throw new IllegalArgumentException("요청일은 필수입니다.");
        }
    }
}
