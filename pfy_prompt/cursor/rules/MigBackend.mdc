**등록/수정** (복잡한 로직):
```java
@Override
@Transactional
@ServiceId("{화면코드}/save")
public Map<String, Object> save(SaveReqDto request) {
    logger.debug("Service Method : save, Input Param={}", request.toString());
    
    // Validation (3개 이상이면 private 메서드로 분리)
    validateSave(request);
    
    try {
        // Insert or Update 로직
        int result = 0;
        if (!StringUtils.hasText(request.getId())) {
            result = dao.insert(request);
        } else {
            result = dao.update(request);
        }
        
        Map<String, Object> response = new HashMap<>();
        response.put("success", result > 0);
        response.put("message", result > 0 ? "저장되었습니다." : "저장 실패");
        
        logger.debug("저장 완료: {} 건", result);
        return response;
        
    } catch (Exception e) {
        logger.error("저장 오류: {}", e.getMessage(), e);
        throw new RuntimeException("저장에 실패했습니다.", e);
    }
}

// Validation 메서드 분리 (3개 이상의 validation)
private void validateSave(SaveReqDto request) {
    if (!StringUtils.hasText(request.getField1())) {
        throw new IllegalArgumentException("필드1은 필수입니다.");
    }
    if (!StringUtils.hasText(request.getField2())) {
        throw new IllegalArgumentException("필드2는 필수입니다.");
    }
    // ... 나머지 validation
}
```

