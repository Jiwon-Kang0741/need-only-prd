## 📝 Example: Complete SearchForm Implementation

```vue
<script setup lang="ts">
import { ref, watch, inject, type Ref } from 'vue';
import type { SearchParams } from './types';

// Props & Emits
interface Props {
  loading?: boolean;
}
const props = withDefaults(defineProps<Props>(), {
  loading: false,
});

const emit = defineEmits<{
  search: [params: SearchParams];
}>();

// Inject searchParams
const searchParams = inject<Ref<SearchParams>>('searchParams');

// Form ref
const searchFormRef = ref();

// Common codes
const prgStatOptions = ref([
  { label: '전체', value: '' },
  { label: '의뢰', value: 'S01' },
  { label: '진행중', value: 'S02' },
  { label: '완료', value: 'S03' },
]);

// ⭐ CRITICAL: Watch searchParams for synchronization
watch(
  () => searchParams.value?.prg_stat,
  (newVal) => {
    if (newVal !== undefined && searchFormRef.value?.form) {
      searchFormRef.value.form.setFieldValue('prg_stat', newVal ?? '');
    }
  }
);

// ⭐ CRITICAL: Update searchParams directly, not form
const handleSearch = () => {
  if (!searchFormRef.value?.form) return;
  
  const formValues = searchFormRef.value.form.getValues();
  
  searchParams.value = {
    ...searchParams.value,
    prg_stat: formValues.prg_stat,
    cont_no: formValues.cont_no,
  };
  
  emit('search', searchParams.value);
};
</script>

<template>
  <SearchForm
    ref="searchFormRef"
    :loading="loading"
    @search="handleSearch"
  >
    <SearchFormItem label="진행상태" name="prg_stat">
      <SelectBox
        name="prg_stat"
        :options="prgStatOptions"
        placeholder="전체"
      />
    </SearchFormItem>
    
    <SearchFormItem label="계약번호" name="cont_no">
      <InputText
        name="cont_no"
        placeholder="계약번호를 입력하세요"
      />
    </SearchFormItem>
  </SearchForm>
</template>
```

