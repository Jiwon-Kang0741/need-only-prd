```

**판단 기준**:
1. 백엔드 DTO 필드명 확인
   - `Pm100SelectProgressSumResDto.java`에서 필드명 확인
   - camelCase면 프론트엔드도 camelCase로 정의
2. DataTable 컬럼 정의 확인
   - `getColumns()`에서 `field: 'CONT_NO'` (대문자) 사용
   - `getRows()`에서 변환 필요
3. SumGrid/ProgressList에서 필드 접근
   - camelCase로 정의했으면 소문자로 접근
   - 또는 변환 함수 사용

#### 2. **Common Code Loading Pattern** (CRITICAL!)
```typescript
// ✅ ALWAYS use useCommonCodeStore
import { useCommonCodeStore } from '@/stores/commonCodeStore';
import { computed } from 'vue';

const commonCodeStore = useCommonCodeStore();

// ⚠️ Load all codes in onMounted
onMounted(async () => {
  const customParam = 'BUSN_SC_IN=A1 PROG_ID=PMDP020';
  
  await commonCodeStore.loadMulti([
    { QueryId: 'BMCM010Query.ContCombo' },
    { QueryId: 'MNPS010Query.StatComboIn', customParam },
    { QueryId: 'COM_PBL_0005', whereClause: "P_CODE_CD='C'" },
  ]);
});

// ⚠️ Use computed for options
const prgStatOptions = computed(() => 
  commonCodeStore.options('MNPS010Query.StatComboIn', true, '전체', '', undefined, customParam)
);
```

#### 3. **Common Code Dynamic Loading** (CRITICAL!)
```typescript
// ✅ Load dependent codes on change
const onContNoChange = (event: any) => {
  const contNo = event.value;
  if (contNo) {
    loadStrCdOptions(contNo);
  }
};

const loadStrCdOptions = async (contNo: string) => {
  const param = `CONT_NO=${contNo}`;
  
  await commonCodeStore.loadMulti([
    { QueryId: 'MNOD090Query.StrCombo', customParam: param }
  ]);
  
  // ⭐ CRITICAL: Pass same customParam to options() for cache matching
  strCdOptions.value = commonCodeStore.options(
    'MNOD090Query.StrCombo', 
    true, 
    '전체', 
    '', 
    undefined, 
    param  // ← Must match loadMulti customParam!
  );
};
```

#### 4. **searchParams Synchronization Pattern** (CRITICAL!)
```typescript
// ✅ ALWAYS use this watch pattern in SearchForm
import { watch, inject, type Ref } from 'vue';

const searchParams = inject<Ref<SearchParams>>('searchParams');
const searchFormRef = ref();

watch(
  () => searchParams.value?.prg_stat,
  (newVal) => {
    // ⚠️ Use !== undefined, NOT if (newVal)
    if (newVal !== undefined && searchFormRef.value?.form) {
      searchFormRef.value.form.setFieldValue('prg_stat', newVal ?? '');
    }
  }
);

// ⚠️ Update searchParams directly, NOT form values
const handleSearch = () => {
  searchParams.value = {
    ...searchParams.value,
    prg_stat: form.value.prg_stat,  // ← Direct assignment
  };
};
```

#### 5. **Ref Access** (CRITICAL!)
```typescript
// ✅ CORRECT - Vue auto-unwraps refs
searchFormRef.value.form.setFieldValue('prg_stat', 'S01');

// ❌ WRONG - Don't use .value.value
searchFormRef.value.form.value.setFieldValue('prg_stat', 'S01');
```

#### 6. **API Parameter Uppercase Conversion** (CRITICAL!)
```typescript
// Backend HQML expects UPPERCASE parameters
// prg_stat → PRG_STAT
// cont_no → CONT_NO

// ✅ Convert to uppercase before API call
const convertToUppercaseParams = (params: Record<string, any>) => {
  return Object.entries(params)
    .filter(([_, v]) => v !== null && v !== undefined && v !== '')
    .reduce((acc, [k, v]) => {
      acc[k.toUpperCase()] = v;
      return acc;
    }, {} as Record<string, any>);
};

// Usage
const response = await api.post('/json/PMDP020-selectDpReqList', {
  data: convertToUppercaseParams(searchParams.value),
});
```

