# 개발 전용 설정
# 비워 두면 axios는 같은 오리진(예: :8081)으로 요청하고, Vite 프록시가 백엔드(:8888)로 넘깁니다(CORS 회피).
# 직접 백엔드 URL을 쓰려면 http://localhost:8888 처럼 넣되, 그때는 Spring 쪽 CORS 설정이 필요합니다.
VITE_API_BASE_URL=
VITE_ENV=development
# Mock 모드: axios baseURL은 빈 문자열(상대 URL)을 사용 (axios.ts 참고).
# 이 값은 mock 모드에서 더 이상 사용되지 않습니다.
VITE_MOCK_BASE_URL=
VITE_MOCK=true
